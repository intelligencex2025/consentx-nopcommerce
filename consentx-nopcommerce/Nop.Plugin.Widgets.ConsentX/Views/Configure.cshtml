@model ConfigurationModel

@{
    Layout = "_ConfigurePlugin";
}

@await Component.InvokeAsync("StoreScopeConfiguration")

<style>
    .consentx-header { display: flex; align-items: center; gap: 14px; margin: 4px 0 18px; }
    .consentx-header img { height: 40px; width: auto; }
    .consentx-header .consentx-tagline { color: #5b6b7b; font-size: 13px; line-height: 1.3; }
    .consentx-status { display: inline-flex; align-items: center; gap: 8px; padding: 8px 14px; border-radius: 8px; font-weight: 600; }
    .consentx-status.connected { background: #e7f7ed; color: #157347; border: 1px solid #b7e4c7; }
    .consentx-status.disconnected { background: #fdecea; color: #b02a37; border: 1px solid #f5c2c7; }
    .consentx-actions { margin: 16px 0 8px; display: flex; gap: 10px; flex-wrap: wrap; }
    .consentx-dot { width: 10px; height: 10px; border-radius: 50%; display: inline-block; }
    .consentx-dot.on { background: #157347; }
    .consentx-dot.off { background: #b02a37; }
</style>

<form asp-controller="ConsentX" asp-action="Configure" method="post">
    <div class="cards-group">
        <div class="card card-default">
            <div class="card-body">

                <div class="consentx-header">
                    <img src="@Url.Content("~/Plugins/Widgets.ConsentX/Content/consentx-logo.svg")"
                         alt="ConsentX" />
                    <div class="consentx-tagline">
                        Cookie consent &amp; CMP — GDPR, CCPA, DPDPA. 1-click connect.
                    </div>
                </div>

                @if (Model.IsConnected)
                {
                    <div class="consentx-status connected">
                        <span class="consentx-dot on"></span>
                        @T("Plugins.Widgets.ConsentX.Status.Connected")
                    </div>
                }
                else
                {
                    <div class="consentx-status disconnected">
                        <span class="consentx-dot off"></span>
                        @T("Plugins.Widgets.ConsentX.Status.NotConnected")
                    </div>
                }

                <div class="consentx-actions">
                    @if (!Model.IsConnected)
                    {
                        <a class="btn btn-primary"
                           href="@Url.Action("ConnectStart", "ConsentX", new { area = "Admin" })">
                            <i class="fas fa-link"></i>&nbsp;@T("Plugins.Widgets.ConsentX.Connect")
                        </a>
                    }
                    else
                    {
                        <a class="btn btn-secondary"
                           href="@Url.Action("ConnectStart", "ConsentX", new { area = "Admin" })">
                            <i class="fas fa-sync"></i>&nbsp;@T("Plugins.Widgets.ConsentX.Connect")
                        </a>
                        <a class="btn btn-danger"
                           href="@Url.Action("Disconnect", "ConsentX", new { area = "Admin" })"
                           onclick="return confirm('@T("Plugins.Widgets.ConsentX.Disconnect")?');">
                            <i class="fas fa-unlink"></i>&nbsp;@T("Plugins.Widgets.ConsentX.Disconnect")
                        </a>
                    }
                    <a class="btn btn-light" target="_blank" rel="noopener" href="@Model.DashboardUrl">
                        <i class="fas fa-external-link-alt"></i>&nbsp;@T("Plugins.Widgets.ConsentX.Dashboard")
                    </a>
                </div>

                @if (!Model.IsConnected && !string.IsNullOrEmpty(Model.SiteHost))
                {
                    <p class="text-muted" style="margin-top:6px;">
                        Connecting will authorize the domain <strong>@Model.SiteHost</strong>
                        and register it in your ConsentX allowlist automatically.
                    </p>
                }

                <hr />

                <div class="form-group row">
                    <div class="col-md-3">
                        <nop-override-store-checkbox asp-for="SiteKey_OverrideForStore" asp-input="SiteKey" asp-store-scope="@Model.ActiveStoreScopeConfiguration" />
                        <nop-label asp-for="SiteKey" />
                    </div>
                    <div class="col-md-9">
                        <nop-editor asp-for="SiteKey" />
                        <span asp-validation-for="SiteKey"></span>
                    </div>
                </div>

                <div class="form-group row">
                    <div class="col-md-3">
                        <nop-override-store-checkbox asp-for="EnableConsentMode_OverrideForStore" asp-input="EnableConsentMode" asp-store-scope="@Model.ActiveStoreScopeConfiguration" />
                        <nop-label asp-for="EnableConsentMode" />
                    </div>
                    <div class="col-md-9">
                        <nop-editor asp-for="EnableConsentMode" />
                        <span asp-validation-for="EnableConsentMode"></span>
                    </div>
                </div>

                <div class="form-group row advanced-setting">
                    <div class="col-md-3">
                        <nop-override-store-checkbox asp-for="AppUrl_OverrideForStore" asp-input="AppUrl" asp-store-scope="@Model.ActiveStoreScopeConfiguration" />
                        <nop-label asp-for="AppUrl" />
                    </div>
                    <div class="col-md-9">
                        <nop-editor asp-for="AppUrl" />
                        <span asp-validation-for="AppUrl"></span>
                    </div>
                </div>

                <div class="form-group row">
                    <div class="col-md-9 offset-md-3">
                        <button type="submit" name="save" class="btn btn-primary">
                            @T("Admin.Common.Save")
                        </button>
                    </div>
                </div>

            </div>
        </div>
    </div>
</form>
